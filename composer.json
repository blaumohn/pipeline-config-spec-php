{
  "name": "pipeline-config-spec/lib",
  "description": "Pipeline/phase based config manifest with Dotenv loading and policy validation.",
  "type": "library",
  "version": "0.1.0",
  "require": {
    "php": ">=8.1",
    "symfony/config": "^7.0",
    "symfony/dotenv": "^7.0",
    "symfony/filesystem": "^7.0",
    "symfony/yaml": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "ConfigPipelineSpec\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ConfigPipelineSpec\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  }
}
