{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["variable-groups", "phases", "pipelines"],
  "additionalProperties": false,
  "properties": {
    "variable-groups": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": { "$ref": "#/$defs/variableDef" }
      }
    },
    "phases": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/phaseRules" }
    },
    "pipelines": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "$ref": "#/$defs/phaseRules" }
      }
    }
  },
  "$defs": {
    "variableDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sources": {
          "type": "array",
          "items": { "type": "string", "enum": ["cli", "local", "file"] }
        },
        "default": {},
        "meta": {
          "type": "object",
          "properties": {
            "desc":    { "type": "string" },
            "notes":   { "type": "string" },
            "example": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    },
    "phaseRules": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/groupSelector" }
        }
      ]
    },
    "groupSelector": {
      "oneOf": [
        { "type": "string", "const": "*" },
        { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      ]
    }
  }
}
